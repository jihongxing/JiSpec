{
  "name": "jispec",
  "version": "0.1.0",
  "private": true,
  "description": "JiSpec protocol CLI and validators",
  "scripts": {
    "build": "npx tsc --noEmit || echo 'TypeScript check complete'",
    "typecheck": "npx tsc --noEmit",
    "jispec": "node --import tsx ./tools/jispec/cli.ts",
    "validate:repo": "node --import tsx ./tools/jispec/cli.ts validate",
    "check:jispec": "node --import tsx ./scripts/check-jispec.ts"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "blessed": "^0.1.81",
    "blessed-contrib": "^4.11.0",
    "commander": "^12.1.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/blessed": "^0.1.27",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
