{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jispec.dev/schemas/context.schema.json",
  "title": "JiSpec Context",
  "type": "object",
  "required": [
    "id",
    "name",
    "owner",
    "purpose",
    "upstream_contexts",
    "downstream_contexts",
    "active_slices"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "owner": {
      "type": "string"
    },
    "purpose": {
      "type": "string"
    },
    "upstream_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "downstream_contexts": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "active_slices": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}
