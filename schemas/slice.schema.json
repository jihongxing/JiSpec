{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://jispec.dev/schemas/slice.schema.json",
  "title": "JiSpec Slice",
  "type": "object",
  "required": [
    "id",
    "title",
    "context_id",
    "lifecycle",
    "priority",
    "goal",
    "source_refs",
    "owners",
    "gates"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "title": {
      "type": "string"
    },
    "context_id": {
      "type": "string"
    },
    "lifecycle": {
      "type": "object",
      "required": ["state"],
      "properties": {
        "state": {
          "type": "string",
          "enum": [
            "proposed",
            "requirements-defined",
            "design-defined",
            "behavior-defined",
            "test-defined",
            "implementing",
            "verifying",
            "accepted",
            "released"
          ]
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": false
    },
    "priority": {
      "type": "string"
    },
    "goal": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "properties": {
        "includes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "excludes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "source_refs": {
      "type": "object",
      "required": [
        "requirement_ids",
        "design_refs"
      ],
      "properties": {
        "requirement_ids": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "design_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "owners": {
      "type": "object",
      "required": [
        "product",
        "engineering"
      ],
      "properties": {
        "product": {
          "type": "string"
        },
        "engineering": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "object",
      "properties": {
        "requirements_ready": {
          "type": "boolean"
        },
        "design_ready": {
          "type": "boolean"
        },
        "behavior_ready": {
          "type": "boolean"
        },
        "test_ready": {
          "type": "boolean"
        },
        "implementation_ready": {
          "type": "boolean"
        },
        "verification_ready": {
          "type": "boolean"
        },
        "accepted": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["slice_id", "kind", "required_state"],
        "properties": {
          "slice_id": {
            "type": "string",
            "description": "Target slice ID"
          },
          "kind": {
            "type": "string",
            "enum": ["requirements", "design", "behavior", "test", "code", "evidence"],
            "description": "Type of artifact dependency"
          },
          "required_state": {
            "type": "string",
            "enum": [
              "proposed",
              "requirements-defined",
              "design-defined",
              "behavior-defined",
              "test-defined",
              "implementing",
              "verifying",
              "accepted",
              "released"
            ],
            "description": "Minimum lifecycle state required from upstream slice"
          },
          "optional": {
            "type": "boolean",
            "default": false,
            "description": "Whether this dependency is optional"
          }
        },
        "additionalProperties": false
      },
      "default": []
    }
  },
  "additionalProperties": true
}
